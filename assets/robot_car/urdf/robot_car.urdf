<?xml version="1.0"?>
<robot name="ackermann_gimbal_robot">

  <material name="blue"><color rgba="0.2 0.2 0.8 1"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>

  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 -1.5708"/> 
      <geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/body.obj"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.225 0.14 0.13"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/></joint>

  <link name="rear_left_wheel"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/></geometry><material name="black"/></visual></link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="rear_left_wheel"/>
    <origin xyz="-0.08 0.085 0.0335" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/></geometry><material name="black"/></visual></link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="rear_right_wheel"/>
    <origin xyz="-0.08 -0.085 0.0335" rpy="0 0 0"/><axis xyz="0 1 0"/>
  </joint>

  <link name="front_left_steer"/>
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/><child link="front_left_steer"/>
    <origin xyz="0.08 0.085 0.0335" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.52" upper="0.52" effort="10.0" velocity="1.0"/>
  </joint>
  <link name="front_left_wheel"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/></geometry><material name="black"/></visual></link>
  <joint name="front_left_wheel_joint" type="continuous"><parent link="front_left_steer"/><child link="front_left_wheel"/><axis xyz="0 1 0"/></joint>

  <link name="front_right_steer"/>
  <joint name="front_right_steer_joint" type="revolute">
    <parent link="base_link"/><child link="front_right_steer"/>
    <origin xyz="0.08 -0.085 0.0335" rpy="0 0 0"/><axis xyz="0 0 1"/><limit lower="-0.52" upper="0.52" effort="10.0" velocity="1.0"/>
  </joint>
  <link name="front_right_wheel"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/></geometry><material name="black"/></visual></link>
  <joint name="front_right_wheel_joint" type="continuous"><parent link="front_right_steer"/><child link="front_right_wheel"/><axis xyz="0 1 0"/></joint>

  <link name="yaw_base"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/yaw_base.obj"/></geometry><material name="gray"/></visual></link>
  <joint name="yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="yaw_base"/>
    <origin xyz="-0.076562 -0.000014 0.128658" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1.0" velocity="1.0"/>
  </joint>

  <link name="lidar_frame"/>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_frame"/>
    <origin xyz="-0.076562 -0.000014 0.128658" rpy="0 0 0"/>
  </joint>

  <link name="pitch_base"><visual><origin rpy="0 0 -1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/pitch_base.obj"/></geometry><material name="gray"/></visual></link>
  <joint name="pitch_joint" type="revolute"><parent link="yaw_base"/><child link="pitch_base"/><origin xyz="0 0 0.057646" rpy="0 0 0"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="1.0" velocity="1.0"/></joint>

  <link name="camera_link"><visual><origin rpy="0 0 1.5708"/><geometry><mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/camera.obj"/></geometry><material name="black"/></visual></link>
  <joint name="camera_joint" type="fixed"><parent link="pitch_base"/><child link="camera_link"/><origin xyz="0 0 0.005" rpy="0 0 0"/></joint>

</robot>