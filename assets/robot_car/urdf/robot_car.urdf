<?xml version="1.0"?>
<robot name="ackermann_robot">

  <material name="blue"><color rgba="0.2 0.2 0.8 1"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/> 
      <geometry>
        <mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/body.obj" scale="1 1 1"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.225 0.14 0.13"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.012" iyz="0" izz="0.012"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Rear wheels -->
  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.07 0.0825 0.0335" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.07 -0.0825 0.0335" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front steering -->
  <link name="front_left_steer">
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </visual>
  </link>

  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_steer"/>
    <origin xyz="0.07 0.0825 0.0335" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.52" upper="0.52" effort="1.0" velocity="1.0"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_right_steer">
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </visual>
  </link>

  <joint name="front_right_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_right_steer"/>
    <origin xyz="0.07 -0.0825 0.0335" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.52" upper="0.52" effort="1.0" velocity="1.0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file:///home/eun/personal_project/humanoid_digital_twin/assets/robot_car/meshes/wheel.obj"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>